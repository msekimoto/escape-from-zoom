{
  "name": "escape-from-zoom",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/ReplicatedStorage/Shared"
      },
      "CharacterModels": {
        "$className": "Folder",
        "$ignoreUnknownInstances": true
      },
      "CharacterRemotes": {
        "$className": "Folder",
        "SelectCharacter": {
          "$className": "RemoteEvent"
        },
        "UseAbility": {
          "$className": "RemoteEvent"
        }
      },
      "GameRemotes": {
        "$className": "Folder",
        "ObjectiveUpdated": {
          "$className": "RemoteEvent"
        },
        "GameFinished": {
          "$className": "RemoteEvent"
        }
      }
    },

    "ServerScriptService": {
      "$path": "src/ServerScriptService"
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "$path": "src/StarterPlayer/StarterPlayerScripts"
      }
    }
  }
}
